					interrupt-names = "threshold";
					#io-channel-cells = <0x01>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					#thermal-sensor-cells = <0x01>;
					io-channels = <0xac 0x4e 0xac 0x4d 0xac 0x4c 0xac 0x53>;
					status = "okay";
					pinctrl-names = "default";
					pinctrl-0 = <0xad>;
					io-channel-names = "THM2_100K\0THM1_100K\0XO_100K\0GPIO4_100K";
					phandle = <0x17>;

					quiet_therm {
						reg = <0x4e>;
						label = "quiet_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					pa_therm {
						reg = <0x4d>;
						label = "pa_therm0";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
					};

					xo_therm {
						reg = <0x4c>;
						label = "xo_therm";

/dts-v1/;

/ {
	#address-cells = <0x02>;
	#size-cells = <0x02>;
	compatible = "jlq,armv8\0jlq,jr510";
	jlq,msm-id = <0x10510 0x01>;
	interrupt-parent = <0x01>;

	chosen {
	};

	aliases {
		ap_wdt0 = "/soc@0/watchdog@30707000";
		serial0 = "/soc@0/uart@30703000";
		serial1 = "/soc@0/uart@3450f000";
		serial2 = "/soc@0/uart@30704000";
		pcm_i2s0 = "/soc@0/pcm_i2s@340e8000";
		pcm_i2s1 = "/soc@0/pcm_i2s@340e9000";
		sdhc0 = "/soc@0/sdhci@34458000";
		sdhc1 = "/soc@0/sdhci@34456000";
		sdhc2 = "/soc@0/sdhci@34457000";
		ufshc1 = "/soc@0/ufshc@24804000";
		syscount = "/timer";
		timer0 = "/soc@0/timer@3070a000";
		i2c3 = "/soc@0/i2c@34502000";
		i2c4 = "/soc@0/i2c@34503000";
		i2c6 = "/soc@0/i2c@30706000";
		swr0 = "/soc@0/bolero-cdc/va-macro@34020000/va_swr_master";
		swr1 = "/soc@0/bolero-cdc/rx-macro@34040000/rx_swr_master";
		spi0 = "/soc@0/spi@30701000";
		spi1 = "/soc@0/spi@34102000";
		spi2 = "/soc@0/spi@30702000";
		malidp0 = "/soc@0/display@30600000";
	};

	memory {
		device_type = "memory";
		reg = <0x00 0x00 0x00 0x00>;
	};

	reserved-memory {
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;

		ramoops@0xe0000000 {
			compatible = "ramoops";
			reg = <0x00 0xe0000000 0x00 0x400000>;
			console-size = <0x200000>;
			ftrace-size = <0x00>;
			pmsg-size = <0x200000>;
		};

		logo_mem_region {
			reg = <0x00 0xa0000000 0x00 0xc00000>;
			phandle = <0xf8>;
		};

		sdi {
			reg = <0x00 0xa0c00000 0x00 0x1a00000>;
			phandle = <0xaf>;
		};

		cm4_dump_mem {
			reg = <0x00 0xa2600000 0x00 0x80000>;
			phandle = <0xb0>;
		};

		linux,cma {
			compatible = "shared-dma-pool";
			alloc-ranges = <0x00 0x98800000 0x00 0x1800000>;
			reusable;
			alignment = <0x00 0x400000>;
			size = <0x00 0x1000000>;
			linux,cma-default;
		};

		smem_region@0x88300000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x00 0x88300000 0x00 0x200000>;
			phandle = <0x42>;
		};

		modem_region@0x80000000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x00 0x80000000 0x00 0x8000000>;
			phandle = <0x95>;
		};

		msadp_region@0x88200000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x00 0x88200000 0x00 0x100000>;
			phandle = <0x96>;
		};

		qbl_region@0x88000000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x00 0x88000000 0x00 0x200000>;
			phandle = <0x97>;
		};

		adsp_mem_1_region@0x95400000 {
			reg = <0x00 0x95400000 0x00 0x2000000>;
			no-map;
			phandle = <0x210>;
		};

		adsp_mem_2_region@0x97400000 {
			compatible = "shared-dma-pool";
			reusable;
			reg = <0x00 0x97400000 0x00 0x400000>;
			phandle = <0x211>;
		};

		adsp_mem_3_region@0x97800000 {
			reg = <0x00 0x97800000 0x00 0x400000>;
			no-map;
			phandle = <0x212>;
		};

		adsp_mem_4_region@0x33080000 {
			reg = <0x00 0x33080000 0x00 0x40000>;
			no-map;
			phandle = <0x213>;
		};

		wlan_msa_region@88700000 {
			compatible = "removed-dma-pool";
			no-map;
			reg = <0x00 0x88700000 0x00 0x200000>;
			phandle = <0x9c>;
		};

		bridge_share_mem@0x98000000 {
			reg = <0x00 0x98000000 0x00 0x100000>;
			no-map;
			phandle = <0x214>;
		};

		bridge_share_mem@0x98100000 {
			reg = <0x00 0x98100000 0x00 0x100000>;
			no-map;
			phandle = <0x215>;
		};

		sshub_share_mem@0x98200000 {
			reg = <0x00 0x98200000 0x00 0x100000>;
			no-map;
			phandle = <0x216>;
		};

		atf_region@0x90000000 {
			reg = <0x00 0x90000000 0x00 0x200000>;
			no-map;
		};

		jtee_region@0x90200000 {
			reg = <0x00 0x90200000 0x00 0x5000000>;
			no-map;
		};

		npu_reserved@0x98300000 {
			reg = <0x00 0x98300000 0x00 0x500000>;
			phandle = <0x88>;
		};
	};

	timer {
		clock-frequency = <0x124f800>;
		compatible = "arm,armv8-timer";
		interrupts = <0x01 0x0d 0x04 0x01 0x0e 0x04 0x01 0x0b 0x04 0x01 0x0a 0x04>;
		phandle = <0x217>;
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu-map {

			cluster0 {
				#cooling-cells = <0x02>;
				phandle = <0x218>;

				core0 {
					cpu = <0x02>;
				};

				core1 {
					cpu = <0x03>;
				};

				core2 {
					cpu = <0x04>;
				};

				core3 {
					cpu = <0x05>;
				};

				core4 {
					cpu = <0x06>;
				};

				core5 {
					cpu = <0x07>;
				};

				core6 {
					cpu = <0x08>;
				};

				core7 {
					cpu = <0x09>;
				};
			};
		};

		idle-states {
			entry-method = "arm,psci";

			pm-cpu-level0 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x1010012>;
				local-timer-stop;
				entry-latency-us = <0x64>;
				exit-latency-us = <0x64>;
				min-residency-us = <0x1388>;
				phandle = <0x0f>;
			};

			pm-cpu-level1 {
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x1010012>;
				local-timer-stop;
				entry-latency-us = <0x64>;
				exit-latency-us = <0x64>;
				min-residency-us = <0x1388>;
				phandle = <0x0b>;
			};

			pm-cluster-level {
				compatible = "arm,idle-state";
				entry-latency-us = <0x1e>;
				exit-latency-us = <0x12c>;
				min-residency-us = <0xfa0>;
				phandle = <0x219>;
			};
		};

		cpu@400 {
			device_type = "cpu";
			compatible = "arm,cortex-a55\0arm,armv8";
			reg = <0x00 0x400>;
			enable-method = "psci";

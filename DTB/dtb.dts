	interrupt-controller@30800000 {
		compatible = "arm,gic-v3";
		#interrupt-cells = <0x03>;
		#address-cells = <0x02>;
		#size-cells = <0x02>;
		ranges;
		interrupt-controller;
		reg = <0x00 0x30800000 0x00 0x10000 0x00 0x30840000 0x00 0x100000 0x00 0x34510040 0x00 0x1c>;
		interrupts = <0x01 0x09 0x04>;
		phandle = <0x01>;
	};

	soc@0 {
		compatible = "simple-bus";
		reg = <0x00 0x00 0x00 0x00>;
		#address-cells = <0x01>;
		#size-cells = <0x01>;
		interrupt-parent = <0x01>;
		ranges = <0x00 0x00 0x00 0xffffffff>;
		phandle = <0x21a>;

		thermal-zones {
			phandle = <0x21b>;

			pm6125-tz {
				polling-delay-passive = <0x64>;
				polling-delay = <0x00>;
				thermal-governor = "step_wise";
				thermal-sensors = <0x13>;
				wake-capable-sensor;

				trips {

					trip0 {
						temperature = <0x17318>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x21c>;
					};

					trip1 {
						temperature = <0x1c138>;
						hysteresis = <0x00>;
						type = "passive";
						phandle = <0x21d>;
					};

					trip2 {
						temperature = <0x23668>;
						hysteresis = <0x00>;
						type = "passive";
					};
				};
			};

			tsens_tz_sensor0 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x14 0x03>;
				wake-capable-sensor;
				phandle = <0x21e>;

				trips {

					trip-point-0 {
						temperature = <0x14c08>;
						hysteresis = <0x4e20>;
						type = "passive";
						phandle = <0x15>;
					};

					trip-point-1 {
						temperature = <0x1c138>;
						hysteresis = <0x4e20>;
						type = "critical";
						phandle = <0x21f>;
					};
				};

				cooling-maps {

					cpu-cdev0 {
						trip = <0x15>;
						cooling-device = <0x02 0xffffffff 0xffffffff>;
					};

					cpu-cdev1 {
						trip = <0x15>;
						cooling-device = <0x06 0xffffffff 0xffffffff>;
					};
				};
			};

			tsens_tz_sensor1 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x14 0x01>;
				phandle = <0x220>;
			};

			tsens_tz_sensor2 {
				polling-delay-passive = <0x00>;
				polling-delay = <0x00>;
				thermal-sensors = <0x14 0x02>;
				phandle = <0x221>;
			};

			tsens_tz_sensor3 {
				polling-delay-passive = <0x00>;

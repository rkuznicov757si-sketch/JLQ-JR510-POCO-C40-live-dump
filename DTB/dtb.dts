			cache-level = <0x02>;
			cache-size = <0x80000>;
			cache-line-size = <0x40>;
			cache-sets = <0x200>;
			phandle = <0x12>;
		};

		cpu_opp_table0 {
			compatible = "operating-points-v2";
			opp-shared;
			phandle = <0x0c>;

			opp-200000000 {

					pm6125_gpio_tm_adcs_pins {
						phandle = <0x27f>;

						pm6125_gpio4_default {
							pins = "gpio4";
							function = "normal";
							bias-high-impedance;
							bias-disable;
							phandle = <0xad>;
						};

						pm6125_gpio7_default {
							pins = "gpio7";
							function = "normal";
							bias-high-impedance;
							bias-disable;
							phandle = <0x14c>;
						};
					};

